# Copie para .env e preencha. NUNCA versione o .env (ver docs/seguranca-lgpd.md §6).
# Nenhum segredo real aqui — só nomes de variável.

# --- App ---
APP_ENV=local
APP_SECRET_KEY=troque-isto-em-prod
LOG_LEVEL=INFO
BUSINESS_TIMEZONE=America/Sao_Paulo
# Origens permitidas para o frontend (CORS). Separar por vírgula.
CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Domínios em produção (Caddy faz TLS automático p/ estes) ---
# DNS de ambos deve apontar p/ o IP do servidor. Ex.: app.suaempresa.com / api.suaempresa.com
APP_DOMAIN=
API_DOMAIN=

# --- Postgres ---
POSTGRES_USER=audit
POSTGRES_PASSWORD=audit
POSTGRES_DB=audit
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# DATABASE_URL = role DONO (migrações/plataforma; é superusuário no Postgres oficial).
# NUNCA usado pelo runtime — superusuário ignora RLS (ver auditoria C-1).
DATABASE_URL=postgresql+psycopg://audit:audit@postgres:5432/audit
# APP_DATABASE_URL = role da APLICAÇÃO (NOSUPERUSER, NOBYPASSRLS) — runtime usa este,
# para o RLS valer de fato. Criado pelo bootstrap (scripts/bootstrap_roles.py).
APP_DATABASE_URL=postgresql+psycopg://app_rw:app_rw@postgres:5432/audit
APP_DB_PASSWORD=app_rw
DB_OWNER=audit

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Object store (MinIO local / S3 em prod) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET=audit-evidence

# --- Secret provider (ADR-11) ---
# local: lê segredos do ambiente. Em prod: vault/file.
SECRET_PROVIDER=env

# --- LLM (injetado via SecretProvider; NUNCA commitar valor real) ---
ANTHROPIC_API_KEY=
LLM_MODEL_STRONG=claude-opus-4-8
LLM_MODEL_CHEAP=claude-haiku-4-5-20251001
LLM_TENANT_TOKEN_BUDGET=2000000

# --- Embeddings (API externa) ---
EMBEDDINGS_PROVIDER=
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=

# --- Integridade: CEIS/CNEP (Portal da Transparência) ---
# Chave GRATUITA: cadastre um e-mail em
# https://api.portaldatransparencia.gov.br/api-de-dados/cadastrar-email
# Sem ela, situação/QSA (BrasilAPI) funcionam; sanções ficam "não verificadas".
PORTAL_TRANSPARENCIA_KEY=

# --- Sienge (por tenant; em prod via SecretProvider namespaced por tenant) ---
# Estes são apenas placeholders de dev. Em prod: tenant/{id}/sienge/{subdomain,user,password}
SIENGE_DEFAULT_SUBDOMAIN=
SIENGE_DEFAULT_USER=
SIENGE_DEFAULT_PASSWORD=

# --- E-mail (alertas) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM=alertas@exemplo.com

# --- Cobrança / Stripe (Fase 2). billing_provider: none|stripe ---
# Desligado por padrão -> sistema funciona sem cobrança. Para ligar: criar
# Products/Prices na Stripe, gravar stripe_price_id em plan.features e preencher:
BILLING_PROVIDER=none
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
# URL pública do app (usada nos redirects do checkout)
APP_PUBLIC_URL=http://localhost:3000

# --- Mitigação automática (Agente Executor). Default log_only = SEGURO ---
# Só age no ERP/e-mail com adapter homologado E tenant.auto_mitigation=true.
ERP_PROVIDER=log_only          # log_only | sienge
NOTIFIER_PROVIDER=log_only     # log_only | smtp
